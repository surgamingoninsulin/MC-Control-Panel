HOST=127.0.0.1
PORT=4200
# Paths are resolved relative to the project root (folder that contains Web-interface/ and Servers/).
# Leave empty to auto-detect <project-root>/Servers (or <project-root>/servers if that exists instead).
SERVER_ROOT=
SERVERS_ROOT=
# Optional override. Leave empty to use automatic RAM calculation.
START_COMMAND=
JAVA_BINARY=java
SERVER_JAR=purpur.jar
USE_NOGUI=true
RAM_AUTO_ENABLED=true
RAM_BASE_GB=2
RAM_RESERVE_OS_GB=2
RAM_MIN_GB=2
RAM_MAX_GB=12
RAM_PER_PLUGIN_MB=50
RAM_PER_WHITELISTED_PLAYER_MB=120
RAM_XMS_RATIO=0.5
UPLOAD_LIMIT_MB=64
MAX_CONCURRENT_OPS=3
BLOCK_EXTENSIONS=
AUDIT_LOG_FILE=panel-audit.log
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
